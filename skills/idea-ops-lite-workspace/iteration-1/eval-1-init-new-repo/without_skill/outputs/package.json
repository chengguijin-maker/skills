{
  "name": "devnotes",
  "version": "0.1.0",
  "description": "A local-first personal knowledge base for developers. Markdown editing, full-text search, and tag management from your terminal.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "devnotes": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "prepare": "npm run build"
  },
  "keywords": [
    "knowledge-base",
    "markdown",
    "notes",
    "cli",
    "terminal",
    "full-text-search",
    "tags",
    "developer-tools",
    "local-first"
  ],
  "author": "",
  "type": "module",
  "license": "MIT",
  "devDependencies": {
    "@types/lunr": "^2.3.7",
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3",
    "inquirer": "^9.2.0",
    "lunr": "^2.3.9",
    "marked": "^12.0.0",
    "marked-terminal": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
